TELEGRAM_BOT_TOKEN=
OWNER_TELEGRAM_ID=
TZ=Europe/Moscow
ESCALATE_TIME=20:00
TELEGRAM_PROXY=
# Локально можно пусто → SQLite data/crm.db
# На Railway: postgres URL от плагина
DATABASE_URL=
WEB_PASSWORD=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
# OPENAI_BASE_URL=
# Авто-вход без одобрения владельца (по умолчанию выкл — заявка в бот)
ALLOW_SELF_JOIN=false

# WB Dashboard → автозадачи по НАШЕМУ складу
WB_DASHBOARD_URL=https://wb-dashboard-production-baf4.up.railway.app
STOCK_WATCH_ENABLED=true
STOCK_WATCH_INTERVAL_MINUTES=180
# алерт если остаток семьи ≤ N (0 = только пустые)
STOCK_OWN_MAX_STOCK=0
# только позиции с продажами
STOCK_MIN_ORDERS=5
STOCK_REQUIRE_BUYOUTS=true
STOCK_MAX_TASKS=10
# 0 = владельцу; или telegram id менеджера
STOCK_ASSIGNEE_TELEGRAM_ID=0
